
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in SkillForge, including their profile information, role, storage usage, and subscription plan.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isBanned": { "type": "boolean" },
        "storageUsedMB": { "type": "number" },
        "storageLimitMB": { "type": "number" },
        "subscriptionPlanId": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "pending_approval", "none"] },
        "lastPaymentTransactionId": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "createdAt", "isBanned", "storageUsedMB", "storageLimitMB", "subscriptionPlanId"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project created by a user, now with marketplace features.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "visibility": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "price": { "type": "number", "description": "Seller's base price." },
        "sellerAccount": { "type": "string", "description": "Account info for payment." },
        "isForSale": { "type": "boolean" },
        "fileURL": { "type": "string", "format": "uri" },
        "fileSizeMB": { "type": "number" }
      },
      "required": ["id", "title", "ownerId", "visibility", "status"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Tracks project purchases and platform commissions.",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "projectTitle": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "sellerId": { "type": "string" },
        "amountPaid": { "type": "number", "description": "Total amount paid by buyer (Seller Price + 10%)." },
        "commission": { "type": "number", "description": "10% platform fee." },
        "paymentProof": { "type": "string", "description": "Transaction ID from EasyPaisa/Bank." },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/projects_public/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": { "$ref": "#/backend/entities/Project" },
          "description": "Stores public projects."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "Stores platform purchase records."
        }
      }
    ]
  }
}
