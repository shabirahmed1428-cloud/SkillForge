
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in SkillForge, including their profile information, role, storage usage, and subscription plan.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The display name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the platform (student, mentor, admin)."
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "isBanned": {
          "type": "boolean",
          "description": "Flag indicating if the user is currently banned from the platform."
        },
        "storageUsedMB": {
          "type": "number",
          "description": "The amount of storage (in megabytes) currently used by the user."
        },
        "storageLimitMB": {
          "type": "number",
          "description": "The maximum amount of storage (in megabytes) allowed for the user."
        },
        "subscriptionPlanId": {
          "type": "string",
          "description": "Reference to the Plan entity."
        },
        "subscriptionStatus": {
          "type": "string",
          "description": "Status of the subscription (active, pending_approval, none).",
          "enum": ["active", "pending_approval", "none"]
        },
        "lastPaymentTransactionId": {
          "type": "string",
          "description": "The last transaction ID submitted for approval."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "createdAt",
        "isBanned",
        "storageUsedMB",
        "storageLimitMB",
        "subscriptionPlanId"
      ]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project created by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Project entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the project."
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to the User who owns the project."
        },
        "visibility": {
          "type": "string",
          "description": "The visibility setting (public, private, team)."
        },
        "status": {
          "type": "string",
          "description": "The current status of the project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "likesCount": {
          "type": "number"
        },
        "viewsCount": {
          "type": "number"
        },
        "fileURL": {
          "type": "string",
          "format": "uri"
        },
        "fileSizeMB": {
          "type": "number"
        },
        "shareKey": {
          "type": "string"
        },
        "shareKeyEnabled": {
          "type": "boolean"
        },
        "teamId": {
          "type": "string",
          "description": "Optional reference to a Team."
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "ownerId",
        "visibility",
        "status",
        "createdAt",
        "updatedAt",
        "likesCount",
        "viewsCount"
      ]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a collaborative team hub protected by a name and password.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Unique name of the team."
        },
        "password": {
          "type": "string",
          "description": "Password required to access the team hub."
        },
        "ownerId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "password", "ownerId", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/projects_public/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Stores public projects."
        }
      },
      {
        "path": "/teams/{teamId}",
        "definition": {
          "entityName": "Team",
          "schema": {
            "$ref": "#/backend/entities/Team"
          },
          "description": "Stores team hub configurations."
        }
      },
      {
        "path": "/teams/{teamId}/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Stores projects shared within a team hub."
        }
      }
    ]
  }
}
