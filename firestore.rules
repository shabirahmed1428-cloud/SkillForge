
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For this prototype, we check if the user's email matches our admin list
      // and they have an entry in the roles_admin collection.
      return isSignedIn() && (
        request.auth.token.email == 'skillforge@admin.com' || 
        request.auth.token.email == 'waqasarham381@gmail.com'
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Allow authenticated users to LIST and GET user profiles
      allow list, get: if isSignedIn();
      
      // Allow users to WRITE only their own data
      allow create, update: if isOwner(userId);
      
      // Allow administrators to delete any user profile
      allow delete: if isAdmin();
    }

    match /projects_public/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isAdmin();

      match /projects/{projectId} {
        allow read, list, write: if isSignedIn(); 
      }
    }

    match /share_keys/{shareKeyId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list, write: if false;
    }
  }
}
